                        <h2>Installation and startup</h2>
                    </header>

                    <p>Content coming soon — see the <a href="{{ _docs_url }}#section-nos-selfhost" style="color:var(--fx-accent);text-decoration:none;border-bottom:1px solid rgba(0,212,255,0.3)" target="_blank" rel="noopener noreferrer">full documentation</a> for the current installation guide.</p>

                    <!-- nav bottom -->
                    <nav class="nos-nav-bar nos-nav-bar--bottom" aria-label="Section navigation">
                        <a class="nos-nav-page" data-section="section-welcome">← Welcome to nOS</a>
