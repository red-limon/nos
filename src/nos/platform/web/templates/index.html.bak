{% block extra_js %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js" crossorigin="anonymous"></script>
<script>
(function() {
    var sidebar = document.getElementById('index-sidebar');
    var overlay = document.getElementById('index-overlay');
    var navToggle = document.getElementById('index-nav-toggle');
    var navLinks = document.getElementById('index-nav-links');
    var sidebarToggle = document.getElementById('index-sidebar-toggle');
    var resizer = document.getElementById('index-resizer');
    var isMobile = function() { return window.innerWidth < 1024; };

    function openSidebar() {
        if (sidebar) { sidebar.classList.add('index-sidebar--open'); sidebar.classList.remove('index-sidebar--hidden'); }
        if (overlay) { overlay.classList.add('index-overlay--open'); overlay.setAttribute('aria-hidden', 'false'); }
    }
    function closeSidebar() {
        if (sidebar) { sidebar.classList.remove('index-sidebar--open'); if (isMobile()) sidebar.classList.remove('index-sidebar--hidden'); }
        if (overlay) { overlay.classList.remove('index-overlay--open'); overlay.setAttribute('aria-hidden', 'true'); }
    }
    function toggleSidebarDesktop() {
        if (!sidebar || isMobile()) return;
        sidebar.classList.toggle('index-sidebar--hidden');
    }
    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', function() {
            if (isMobile()) {
                if (sidebar && sidebar.classList.contains('index-sidebar--open')) closeSidebar();
                else openSidebar();
            } else {
                toggleSidebarDesktop();
            }
        });
    }
    if (navToggle) {
        navToggle.addEventListener('click', function() {
            navLinks.classList.toggle('index-nav__links--open');
            navToggle.setAttribute('aria-expanded', navLinks.classList.contains('index-nav__links--open'));
        });
    }
    if (overlay) overlay.addEventListener('click', closeSidebar);
    window.addEventListener('resize', function() { if (!isMobile()) closeSidebar(); });

    // Section page switching (one page visible at a time)
    var contentArea = document.querySelector('.index-content');

    function showSection(requestedId) {
        var id = requestedId;
        var scrollToId = null;
        // In-page anchors that are not top-level .nos-page (scroll after showing parent page)
        if (id === 'section-api-node-run-dynamic') {
            scrollToId = id;
            id = 'section-api-node-run';
        }
        // hide all pages
        document.querySelectorAll('.nos-page').forEach(function(p) {
            p.classList.remove('active');
        });
        // show target page
        var page = document.getElementById(id);
        if (page) {
            page.classList.add('active');
            if (contentArea) contentArea.scrollTo({ top: 0, behavior: 'instant' });
            if (scrollToId) {
                var anchor = document.getElementById(scrollToId);
                if (anchor) {
                    requestAnimationFrame(function() {
                        anchor.scrollIntoView({ block: 'start', behavior: 'smooth' });
                    });
                }
            }
        }
        // highlight active sidebar link (use requestedId so sub-anchors match their tree item)
        document.querySelectorAll('.index-sidebar .index-tree-link--inpage').forEach(function(l) {
            l.classList.toggle('active', l.getAttribute('data-section') === requestedId);
        });
    }

    // Sidebar links
    document.querySelectorAll('.index-sidebar .index-tree-link--inpage').forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            var sec = link.getAttribute('data-section');
            if (sec) {
                showSection(sec);
                if (isMobile()) closeSidebar();
            }
        });
    });

    // Prev/next nav bars
    document.querySelectorAll('.nos-nav-page').forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            var sec = link.getAttribute('data-section');
            if (sec) showSection(sec);
        });
    });

    // Activate initial page (welcome)
    showSection('section-welcome');

    // Syntax highlight Python blocks (Highlight.js)
    if (typeof hljs !== 'undefined') {
        document.querySelectorAll('pre.nos-api-signature code.language-python').forEach(function (el) {
            hljs.highlightElement(el);
        });
    }

    document.querySelectorAll('.index-sidebar [data-toggle]').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var id = btn.getAttribute('data-toggle');
            var children = document.getElementById('children-' + id);
            var arrow = btn.querySelector('.index-tree-toggle');
            if (children) {
                children.classList.toggle('expanded');
                if (arrow) arrow.classList.toggle('expanded');
            }
        });
    });

    if (resizer && sidebar) {
        var startX, startW;
        resizer.addEventListener('mousedown', function(e) {
            e.preventDefault();
            startX = e.clientX;
            startW = sidebar.offsetWidth;
            function move(e) {
                var dx = e.clientX - startX;
                var w = Math.max(200, Math.min(window.innerWidth * 0.5, startW + dx));
                sidebar.style.width = w + 'px';
            }
            function up() {
                document.removeEventListener('mousemove', move);
                document.removeEventListener('mouseup', up);
            }
            document.addEventListener('mousemove', move);
            document.addEventListener('mouseup', up);
        });
    }

    window.addEventListener('load', function() {
        if (typeof lucide !== 'undefined') lucide.createIcons();
    });
})();
</script>
{# Chat simulation script - commented out
<script>
(function () {
    function run() {
        var userText = "Create an app that sends a welcome message to new customers via WhatsApp. Message: Hi! Welcome to our company — we're glad to have you on board.";
        var userMessage = "Hi! Welcome to our company — we're glad to have you on board.";

        function streamText(selector, text, delay, onComplete) {
            var el = document.querySelector(selector + ' .streamed-text');
            var cursor = document.querySelector(selector + ' .stream-cursor');
            if (!el) return;
            var i = 0;
            var charDelay = 35 + Math.random() * 25;
            var pauseAfter = 900;
            function type() {
                if (i < text.length) {
                    el.textContent += text[i];
                    var lastChar = text[i];
                    i++;
                    var wait = charDelay;
                    if (lastChar === '\n') {
                        var soFar = el.textContent;
                        if (soFar.endsWith('Reasoning...\n') || soFar.endsWith('Assembling the app...\n')) {
                            wait = pauseAfter;
                        }
                    }
                    setTimeout(type, wait);
                } else {
                    if (cursor) { cursor.style.animation = 'none'; cursor.style.opacity = '0'; }
                    if (onComplete) onComplete();
                }
            }
            setTimeout(type, delay);
        }

        function nosStream() {
            var part1 = "Creating app welcome_new_customer…\nReasoning...\n";
            var part2 = "Assembling the app...\nI've created the app. Should I run it now, or would you like to specify a schedule?";
            var tasks = document.querySelector('.nos-task-list');
            var part1El = document.querySelector('.nos-streaming-turn .nos-part1 .streamed-text');
            var part1Cursor = document.querySelector('.nos-streaming-turn .nos-part1 .stream-cursor');
            var part2Wrap = document.querySelector('.nos-streaming-turn .nos-part2');
            var part2El = document.querySelector('.nos-streaming-turn .nos-part2 .streamed-text');
            var part2Cursor = document.querySelector('.nos-streaming-turn .nos-part2 .stream-cursor');
            var i = 0, charDelay = 35 + Math.random() * 25;
            function typePart1() {
                if (i < part1.length) {
                    part1El.textContent += part1[i];
                    i++;
                    setTimeout(typePart1, part1[i - 1] === '\n' && part1El.textContent.endsWith('Reasoning...\n') ? 900 : charDelay);
                } else {
                    part1Cursor.style.animation = 'none';
                    part1Cursor.style.opacity = '0';
                    tasks.style.display = 'block';
                    var items = tasks.querySelectorAll('.task-item');
                    items.forEach(function (li, idx) {
                        setTimeout(function () { li.style.opacity = '1'; }, idx * 280);
                    });
                    part2Wrap.style.display = 'block';
                    setTimeout(function () {
                        i = 0;
                        function typePart2() {
                            if (i < part2.length) {
                                part2El.textContent += part2[i];
                                i++;
                                setTimeout(typePart2, part2[i - 1] === '\n' && part2El.textContent.endsWith('Assembling the app...\n') ? 900 : charDelay);
                            } else {
                                part2Cursor.style.animation = 'none';
                                part2Cursor.style.opacity = '0';
                                systemStream('.system-streaming-turn', systemLines1, 500, runExample2);
                            }
                        }
                        typePart2();
                    }, 900);
                }
            }
            setTimeout(typePart1, 600);
        }

        function systemStream(selector, lines, delay, onComplete) {
            var container = document.querySelector(selector + ' .console-stream');
            var cursor = document.querySelector(selector + ' .stream-cursor');
            if (!container) return;
            var lineDelay = 450;
            var charDelay = 25 + Math.random() * 15;
            var lineIdx = 0;
            var charIdx = 0;
            function streamLine() {
                if (lineIdx >= lines.length) {
                    if (cursor) { cursor.style.animation = 'none'; cursor.style.opacity = '0'; }
                    if (onComplete) onComplete();
                    return;
                }
                var line = lines[lineIdx];
                if (charIdx < line.length) {
                    container.textContent += line[charIdx];
                    charIdx++;
                    setTimeout(streamLine, charDelay);
                } else {
                    container.textContent += '\n';
                    lineIdx++;
                    charIdx = 0;
                    setTimeout(streamLine, lineDelay);
                }
            }
            setTimeout(streamLine, delay);
        }

        var userText2 = "Create an app to analyze balance sheet data and write a final report with comments and charts. Include PDF generation that I can download.";
        var systemLines2 = [
            "[12:04:12] $ run balance_report",
            "Connecting to document repository",
            "Extracting documents",
            "Analyzing documents",
            "Producing charts",
            "Saving PDF: balance_report_2024Q3.pdf",
            "Completed successfully — report generated, ready to download"
        ];

        function nosStream2() {
            var part1 = "Creating app balance_report…\nReasoning...\n";
            var part2 = "Assembling the app...\nI've created the app. Should I run it now?";
            var tasks = document.querySelector('.nos-streaming-turn-2 .nos-task-list');
            var part1El = document.querySelector('.nos-streaming-turn-2 .nos-part1 .streamed-text');
            var part1Cursor = document.querySelector('.nos-streaming-turn-2 .nos-part1 .stream-cursor');
            var part2Wrap = document.querySelector('.nos-streaming-turn-2 .nos-part2');
            var part2El = document.querySelector('.nos-streaming-turn-2 .nos-part2 .streamed-text');
            var part2Cursor = document.querySelector('.nos-streaming-turn-2 .nos-part2 .stream-cursor');
            var i = 0, charDelay = 35 + Math.random() * 25;
            function typePart1() {
                if (i < part1.length) {
                    part1El.textContent += part1[i];
                    i++;
                    setTimeout(typePart1, part1[i - 1] === '\n' && part1El.textContent.endsWith('Reasoning...\n') ? 900 : charDelay);
                } else {
                    part1Cursor.style.animation = 'none';
                    part1Cursor.style.opacity = '0';
                    tasks.style.display = 'block';
                    var items = tasks.querySelectorAll('.task-item');
                    items.forEach(function (li, idx) {
                        setTimeout(function () { li.style.opacity = '1'; }, idx * 280);
                    });
                    part2Wrap.style.display = 'block';
                    setTimeout(function () {
                        i = 0;
                        function typePart2() {
                            if (i < part2.length) {
                                part2El.textContent += part2[i];
                                i++;
                                setTimeout(typePart2, part2[i - 1] === '\n' && part2El.textContent.endsWith('Assembling the app...\n') ? 900 : charDelay);
                            } else {
                                part2Cursor.style.animation = 'none';
                                part2Cursor.style.opacity = '0';
                                systemStream('.system-streaming-turn-2', systemLines2, 500, null);
                            }
                        }
                        typePart2();
                    }, 900);
                }
            }
            setTimeout(typePart1, 400);
        }

        function runExample2() {
            document.querySelector('[data-example="1"]').classList.add('chat-example-hidden');
            document.querySelector('[data-example="2"]').classList.remove('chat-example-hidden');
            streamText('.user-streaming-turn-2', userText2, 600, nosStream2);
        }

        var systemLines1 = [
            "[12:03:45] $ run welcome_new_customer",
            "Connecting to CRM",
            "Extracting new customers",
            "Sending WhatsApp message: " + userMessage,
            "Completed successfully — 23 messages sent"
        ];
        streamText('.user-streaming-turn', userText, 800, nosStream);
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
    } else {
        run();
    }
})();
</script>
#}
{% endblock %}
