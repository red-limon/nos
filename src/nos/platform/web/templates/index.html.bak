{% extends "base.html" %}
{% block extra_head %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700&family=Playfair+Display:ital@1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" crossorigin="anonymous">
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
{% endblock %}
{% block extra_css %}
    <style>
        :root {
            --fx-bg-dark: #0a0e17;
            --fx-bg-card: rgba(15, 23, 42, 0.85);
            --fx-border: rgba(0, 212, 255, 0.25);
            --fx-accent: #00d4ff;
            --fx-text: #e2e8f0;
            --fx-text-muted: #94a3b8;
            --fx-glow: 0 0 20px rgba(0, 212, 255, 0.15);
            --fx-glow-strong: 0 0 30px rgba(0, 212, 255, 0.25);
            --nav-download: #34d399;
            --nav-docs: #f59e0b;
            --nav-apps: #00d4ff;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }
        .landing-nos {
            height: 100vh;
            min-height: 100%;
            display: flex;
            flex-direction: column;
            font-family: system-ui, sans-serif;
            background: var(--fx-bg-dark);
            background-image:
                linear-gradient(180deg, rgba(0, 212, 255, 0.06) 0%, transparent 50%),
                radial-gradient(ellipse 80% 50% at 50% 0%, rgba(0, 212, 255, 0.12) 0%, transparent 50%);
            color: var(--fx-text);
            overflow: hidden;
        }
        .nos-n { font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-weight: 400; }
        /*
        .nos-logo-mark text.nos-n {
            text-anchor: middle;
            dominant-baseline: central;
            alignment-baseline: central;
        }
        */

        /* ----- Navbar: fixed top, logo + nOS | Download, Apps, Github | Log in ----- */
        .index-nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.6rem 1rem;
            background: rgba(10, 14, 23, 0.95);
            border-bottom: 1px solid var(--fx-border);
            backdrop-filter: blur(12px);
        }
        .index-nav__left {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }
        .index-nav__brand {
            display: inline-flex;
            align-items: center;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--fx-accent);
            letter-spacing: 0.05em;
            font-family: 'Orbitron', sans-serif;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0.45rem 0.6rem;
            border-radius: 8px;
            transition: color 0.2s, background 0.2s;
        }
        .index-nav__brand:hover { color: #fff; text-shadow: 0 0 15px rgba(0, 212, 255, 0.5); background: rgba(0, 212, 255, 0.08); }

        .index-nav__links {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }
        .index-nav__links a {
            padding: 0.45rem 0.85rem;
            border-radius: 8px;
            color: var(--fx-text-muted);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: color 0.2s, background 0.2s;
        }
        .index-nav__links a:hover {
            color: var(--fx-accent);
            background: rgba(0, 212, 255, 0.08);
        }
        .index-nav__login {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.5rem 0.9rem;
            border-radius: 10px;
            color: var(--fx-accent);
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid var(--fx-border);
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        .index-nav__login:hover {
            background: rgba(0, 212, 255, 0.2);
            border-color: var(--fx-accent);
            box-shadow: 0 0 12px rgba(0, 212, 255, 0.25);
        }
        .index-nav__login svg { width: 18px; height: 18px; flex-shrink: 0; }

        .index-nav__toggle {
            display: none;
            align-items: center;
            justify-content: center;
            width: 40px; height: 40px;
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid var(--fx-border);
            border-radius: 8px;
            color: var(--fx-accent);
            cursor: pointer;
            transition: background 0.2s;
        }
        .index-nav__toggle:hover { background: rgba(0, 212, 255, 0.2); }
        .index-nav__toggle svg { width: 22px; height: 22px; }
        /* Desktop: nav toggle (hamburger for menu) hidden; mobile: show toggler + nOS */
        .index-nav__menu-toggler { display: none; }
        @media (max-width: 768px) {
            .index-nav__links { display: none; }
            .index-nav__links.index-nav__links--open {
                display: flex;
                position: fixed;
                top: 52px; left: 0; right: 0;
                flex-direction: column;
                padding: 1rem;
                background: rgba(10, 14, 23, 0.98);
                border-bottom: 1px solid var(--fx-border);
                z-index: 999;
            }
            .index-nav__links.index-nav__links--open a { padding: 0.65rem 1rem; width: 100%; }
            .index-nav__menu-toggler { display: flex; }
        }

        /* ----- Main: subito sotto la navbar, copre tutto il body ----- */
        .index-main {
            display: flex;
            flex: 1;
            min-height: 0;
            margin: 0;
            padding: 0;
            margin-top: 52px;
            height: calc(100vh - 52px);
            overflow: hidden;
        }
        .index-sidebar {
            width: 280px;
            min-width: 200px;
            max-width: 50%;
            flex-shrink: 0;
            background: var(--fx-bg-card);
            border-right: 1px solid var(--fx-border);
            overflow-y: auto;
            overflow-x: hidden;
            transition: transform 0.25s ease, width 0.2s ease;
        }
        .index-sidebar__inner { padding: 1rem 0.75rem; }
        .index-resizer {
            width: 6px;
            flex-shrink: 0;
            background: transparent;
            cursor: col-resize;
            transition: background 0.15s;
        }
        .index-resizer:hover, .index-resizer:active { background: rgba(0, 212, 255, 0.2); }
        .index-content {
            flex: 1;
            min-width: 0;
            min-height: 100%;
            overflow-y: auto;
            overflow-x: hidden;
            background: var(--fx-bg-dark);
            padding: 2rem;
        }
        .index-content__placeholder {
            max-width: 560px;
            color: var(--fx-text-muted);
            font-size: 1rem;
            line-height: 1.7;
        }
        .index-content__placeholder h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.5rem;
            color: var(--fx-accent);
            margin-bottom: 0.75rem;
        }
        .index-sidebar--hidden { width: 0; min-width: 0; overflow: hidden; border-right: none; }
        .index-sidebar--hidden + .index-resizer { display: none; }
        @media (max-width: 1023px) {
            .index-sidebar {
                position: fixed;
                top: 52px; left: 0; bottom: 0;
                z-index: 800;
                width: 300px;
                max-width: 85vw;
                transform: translateX(-100%);
                box-shadow: 4px 0 24px rgba(0,0,0,0.3);
            }
            .index-sidebar.index-sidebar--open { transform: translateX(0); }
            .index-resizer { display: none; }
            .index-sidebar--hidden { width: 0; min-width: 0; }
        }
        .index-overlay {
            display: none;
            position: fixed;
            inset: 0;
            top: 52px;
            background: rgba(0,0,0,0.5);
            z-index: 750;
            opacity: 0;
            transition: opacity 0.25s;
        }
        .index-overlay.index-overlay--open {
            display: block;
            opacity: 1;
        }
        @media (min-width: 1024px) {
            .index-overlay { display: none !important; }
        }

        /* ----- Docs tree (same as docs offcanvas) ----- */
        .index-tree { list-style: none; }
        .index-tree-item { margin: 0; }
        .index-tree-link {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0.75rem;
            color: var(--fx-text-muted);
            text-decoration: none;
            font-size: 0.9rem;
            border-radius: 6px;
            transition: color 0.2s, background 0.2s;
        }
        .index-tree-link:hover { background: rgba(0, 212, 255, 0.08); color: var(--fx-accent); }
        .index-tree-link--inpage.active { background: rgba(0, 212, 255, 0.1); color: var(--fx-accent); font-weight: 500; }
        .index-tree-link .menu-icon,
        .index-tree-head .menu-icon {
            width: 1rem;
            height: 1rem;
            flex-shrink: 0;
            opacity: 0.88;
        }
        .index-tree-toggle {
            margin-left: auto;
            font-size: 0.65rem;
            transition: transform 0.2s;
        }
        .index-tree-toggle.expanded { transform: rotate(90deg); }
        .index-tree-children {
            list-style: none;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.25s ease;
        }
        .index-tree-children.expanded { max-height: 2000px; }
        .index-tree-children .index-tree-link { padding-left: 1.5rem; font-size: 0.85rem; }
        .index-tree-children .index-tree-children .index-tree-link { padding-left: 2.25rem; }
        .index-tree-children .index-tree-children .index-tree-children .index-tree-link { padding-left: 3rem; }
        .index-tree-children .index-tree-children .index-tree-children .index-tree-children .index-tree-link { padding-left: 3.75rem; }
        .index-tree-children .index-tree-children .index-tree-children .index-tree-children .index-tree-children .index-tree-link { padding-left: 4.5rem; }
        .index-tree-head {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.5rem 0.75rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--fx-accent);
            opacity: 0.9;
        }

        .landing-grid { display: none; }
        .hero-section {
            background: var(--fx-bg-card);
            border: 1px solid var(--fx-border);
            padding: 2.5rem 2rem;
            border-radius: 16px;
            backdrop-filter: blur(16px);
            box-shadow: var(--fx-glow);
            width: 100%;
            max-width: 880px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1.75rem;
            text-align: center;
            min-height: 420px;
        }
        @media (min-width: 768px) {
            .hero-section {
                flex-direction: row;
                align-items: center;
                justify-content: center;
                gap: 2.5rem;
                padding: 3rem 2.5rem;
                min-height: 380px;
            }
        }
        .hero-brand {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
            flex-shrink: 0;
            text-align: center;
        }
        @media (min-width: 768px) {
            .hero-brand { align-items: flex-start; text-align: left; gap: 1rem; }
        }
        .hero-section:hover { box-shadow: var(--fx-glow-strong); }
        .hero-title-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1.5rem;
            padding: 0.25rem 0;
            font-family: 'Orbitron', sans-serif;
            font-size: 3rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            color: var(--fx-accent);
            text-shadow: 0 0 40px rgba(0, 212, 255, 0.45);
            flex-shrink: 0;
        }
        @media (min-width: 768px) {
            .hero-title-row {
                font-size: 3.5rem;
                letter-spacing: 0.1em;
                justify-content: flex-start;
            }
        }
        .logo-flying-net {
            perspective: 200px;
        }
        .logo-flying-net .grid-sheet {
            transform-origin: 24px 24px;
            animation: sheet-float 5s ease-in-out infinite;
        }
        @keyframes sheet-float {
            0%, 100% { transform: rotate(-28deg) rotateX(3deg); }
            50% { transform: rotate(-26deg) rotateX(-2deg); }
        }
        .logo-lattice {
            display: block;
            width: 6.5rem;
            height: 6.5rem;
            min-width: 6.5rem;
            min-height: 6.5rem;
            filter: drop-shadow(0 0 28px rgba(0, 212, 255, 0.7));
            flex-shrink: 0;
        }
        @media (min-width: 768px) {
            .hero-brand .logo-lattice {
                width: 7.5rem;
                height: 7.5rem;
                min-width: 7.5rem;
                min-height: 7.5rem;
            }
        }
        .logo-lattice .line-flow {
            stroke: var(--fx-accent);
            stroke-width: 1.2;
            fill: none;
        }
        .logo-lattice .node-pulse {
            fill: var(--fx-accent);
            stroke: none;
            opacity: 0.6;
        }
        .logo-lattice .line-glow {
            stroke: var(--fx-accent);
            stroke-width: 1.2;
        }
        .logo-lattice .line-glow.line-d1 { stroke-width: 0.9; }
        .logo-lattice .line-glow.line-d2 { stroke-width: 0.9; }
        .logo-lattice .line-glow.line-d3 { stroke-width: 0.9; }
        .logo-lattice .line-glow.line-d4 { stroke-width: 0.9; }
        .hero-tagline {
            color: var(--fx-text-muted);
            font-size: 1.1rem;
            line-height: 1.65;
            margin: 0;
            max-width: 360px;
        }
        @media (min-width: 768px) {
            .hero-tagline {
                font-size: 1.2rem;
                max-width: 400px;
            }
        }
        .hero-links {
            margin-top: 0.5rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--fx-border);
            width: 100%;
            align-self: flex-start;
            text-align: left;
        }
        .hero-links ul {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 1.25rem 2rem;
            justify-content: flex-start;
        }
        @media (min-width: 768px) {
            .hero-links {
                border-top: none;
                padding-top: 0;
                margin-top: 0;
                border-left: 1px solid var(--fx-border);
                padding-left: 2rem;
                width: auto;
            }
            .hero-links ul { justify-content: flex-start; }
        }
        .hero-links li a {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            color: var(--fx-accent);
            text-decoration: none;
            font-size: 1rem;
            transition: color 0.2s, transform 0.2s;
            line-height: 1.4;
        }
        .hero-links li a:hover { color: #38bdf8; transform: translateX(2px); }
        .hero-links .link-title {
            display: inline-flex;
            align-items: baseline;
            gap: 0.35rem;
            font-family: 'Orbitron', sans-serif;
            font-weight: 600;
            font-size: 0.95rem;
            letter-spacing: 0.06em;
            margin-bottom: 0.2rem;
            line-height: 1.35;
        }
        .hero-links .link-icon {
            width: 1em;
            height: 1em;
            flex-shrink: 0;
            position: relative;
            top: 0.08em;
        }
        .hero-links .link-desc {
            display: block;
            color: var(--fx-text-muted);
            font-size: 0.9rem;
            line-height: 1.4;
        }
        .ai-cta {
            text-align: center;
            margin-top: 1.5rem;
        }
        .ai-cta-text {
            display: block;
            color: var(--fx-text-muted);
            font-size: 0.9rem;
            margin-bottom: 0.85rem;
        }
        .btn-explore {
            font-family: 'Orbitron', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.15), rgba(0, 212, 255, 0.05));
            color: var(--fx-accent);
            border: 1px solid var(--fx-accent);
            padding: 0.85rem 1.75rem;
            font-size: 0.95rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            cursor: pointer;
            border-radius: 8px;
            transition: all 0.3s ease;
            text-decoration: none;
        }
        .btn-explore:hover {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.25), rgba(0, 212, 255, 0.1));
            box-shadow: 0 0 25px rgba(0, 212, 255, 0.3);
            transform: translateY(-2px);
        }
        .btn-explore .btn-cube-icon {
            flex-shrink: 0;
            width: 1.75em;
            height: 1.75em;
        }
        .btn-explore .btn-cube-icon line,
        .btn-explore .btn-cube-icon path {
            stroke: currentColor;
            stroke-width: 1.2;
            fill: none;
        }
        .btn-explore .btn-cube-icon circle { fill: currentColor; }
        .btn-explore .arrow { transition: transform 0.3s; }
        .btn-explore:hover .arrow { transform: translateX(4px); }

        /* Agent demo chat section */
        .agent-demo {
            background: var(--fx-bg-card);
            border: 1px solid var(--fx-border);
            border-radius: 12px;
            padding: 1.25rem;
            backdrop-filter: blur(12px);
            box-shadow: var(--fx-glow);
            min-height: 420px;
            max-height: 70vh;
            display: flex;
            flex-direction: column;
        }
        .agent-demo:hover { box-shadow: var(--fx-glow-strong); }
        .agent-demo-chat {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            overflow-y: auto;
            overflow-x: hidden;
        }
        .chat-turn {
            display: flex;
            gap: 0.6rem;
            align-items: flex-start;
            font-size: 0.78rem;
            line-height: 1.5;
        }
        .chat-turn.user .chat-role { background: rgba(139, 92, 246, 0.25); color: #c4b5fd; }
        .chat-turn.nos .chat-role { background: rgba(0, 212, 255, 0.2); color: var(--fx-accent); }
        .chat-turn.system .chat-role { background: rgba(255, 165, 0, 0.15); color: #ffa500; }
        .chat-role {
            flex-shrink: 0;
            padding: 0.15rem 0.4rem;
            border-radius: 6px;
            font-size: 0.62rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .chat-body {
            flex: 1;
            min-width: 0;
        }
        .chat-body code {
            background: rgba(0, 212, 255, 0.15);
            padding: 0.1em 0.35em;
            border-radius: 4px;
            font-size: 0.9em;
        }
        .streaming-response {
            position: relative;
        }
        .stream-cursor {
            display: inline-block;
            width: 6px;
            height: 1em;
            background: var(--fx-accent);
            margin-left: 2px;
            vertical-align: text-bottom;
            animation: cursor-blink 0.8s step-end infinite;
        }
        @keyframes cursor-blink {
            50% { opacity: 0; }
        }
        .chat-console {
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 165, 0, 0.25);
            border-radius: 8px;
            padding: 0.6rem 0.85rem;
            font-family: 'ui-monospace', 'Monaco', 'Consolas', monospace;
            font-size: 0.66rem;
            line-height: 1.5;
            color: #94a3b8;
        }
        .chat-console .prompt { color: #22c55e; }
        .chat-console .ts { color: #64748b; }
        .chat-console .console-stream { display: block; }
        .system-streaming-turn .stream-cursor,
        .system-streaming-turn-2 .stream-cursor { background: #22c55e; }
        .chat-console .ok { color: #22c55e; }
        .chat-console .info { color: var(--fx-accent); }
        .nos-task-list { color: var(--fx-text-muted); font-size: 0.75rem; }
        .chat-example { display: flex; flex-direction: column; gap: 1rem; }
        .chat-example-hidden { display: none !important; }
        .nos-task-list li { margin: 0.2rem 0; transition: opacity 0.3s ease; }

        /* Presentation panel - side by side with hero on desktop */
        .presentation-panel {
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 1.75rem;
            width: 100%;
            flex: 1;
            min-width: 0;
        }
        @media (min-width: 900px) {
            .presentation-panel {
                flex: 0 0 52%;
                max-width: 560px;
                padding: 1rem 0 1rem 1.5rem;
                text-align: left;
                align-items: flex-start;
                border-left: 1px solid var(--fx-border);
            }
        }
        .presentation-panel .presentation-section {
            width: 100%;
            padding: 0.6rem 0;
            text-align: center;
        }
        @media (min-width: 900px) {
            .presentation-panel .presentation-section {
                text-align: left;
                padding: 0.6rem 0;
            }
        }
        .presentation-panel .presentation-section h2 {
            margin-bottom: 0.4rem;
            font-size: 0.95rem;
        }
        .presentation-panel .presentation-section p {
            font-size: 0.9rem;
            max-width: none;
        }
        .presentation-section {
            width: 100%;
            padding: 2rem 1rem;
            text-align: center;
        }
        .presentation-section h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            color: var(--fx-accent);
            margin-bottom: 0.75rem;
        }
        .presentation-section p {
            color: var(--fx-text-muted);
            font-size: 0.95rem;
            line-height: 1.65;
            max-width: 560px;
            margin: 0 auto;
        }
        /* Evolution / API section */
        .evolution-row {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            gap: 0.75rem;
            margin: 2rem auto;
            max-width: 640px;
        }
        .evolution-chip {
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid var(--fx-border);
            color: var(--fx-text);
            padding: 0.5rem 1rem;
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 500;
        }
        .evolution-arrow {
            color: var(--fx-accent);
            font-size: 1rem;
        }
        .api-badges {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }
        .api-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: var(--fx-bg-card);
            border: 1px solid var(--fx-border);
            padding: 0.5rem 1rem;
            border-radius: 8px;
            color: var(--fx-text-muted);
            font-size: 0.85rem;
            font-family: 'ui-monospace', monospace;
        }
        .api-badge span { color: var(--fx-accent); }

        @media (max-width: 768px) {
            .presentation-section { padding: 1.5rem 0.75rem; }
            .hero-title-row { font-size: 2.5rem; letter-spacing: 0.1em; }
            .hero-section { min-height: 360px; padding: 2rem 1.5rem; }
        }

        /* ── Section pages (one visible at a time) ───────────────────── */
        .nos-page { display: none; }
        .nos-page.active { display: block; }

        /* ── Welcome page ─────────────────────────────────────────────── */
        .nos-welcome {
            width: 100%;
            max-width: none;
            display: flex;
            flex-direction: column;
            gap: 2.25rem;
        }
        .nos-welcome-hero {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        /*
        .nos-logo-mark {
            width: clamp(4.5rem, 12vw, 5.75rem);
            height: auto;
            margin-bottom: 1rem;
            color: var(--fx-accent);
            filter: drop-shadow(0 0 14px rgba(0, 212, 255, 0.28)) drop-shadow(0 4px 24px rgba(0, 0, 0, 0.45));
            transform: rotate(-6deg);
            animation: nos-logo-float 6s ease-in-out infinite;
        }
        @keyframes nos-logo-float {
            0%, 100% { transform: rotate(-6deg) translateY(0); }
            50% { transform: rotate(-6deg) translateY(-5px); }
        }
        @media (prefers-reduced-motion: reduce) {
            .nos-logo-mark { animation: none; }
        }
        */
        .nos-welcome-hero h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--fx-accent);
            letter-spacing: 0.06em;
            margin-bottom: 0.6rem;
        }
        .nos-welcome-tagline {
            color: var(--fx-text);
            font-size: 1.05rem;
            line-height: 1.65;
        }
        .nos-welcome-lead {
            color: var(--fx-text-muted);
            font-size: 0.93rem;
            line-height: 1.8;
        }
        .nos-welcome-lead strong {
            color: var(--fx-text);
            font-weight: 600;
        }
        .nos-welcome-leads {
            display: flex;
            flex-direction: column;
            gap: 1.1rem;
        }
        .nos-divider {
            border: none;
            border-top: 1px solid var(--fx-border);
            margin: 0;
        }
        .nos-welcome-section { display: flex; flex-direction: column; gap: 1.1rem; }
        .nos-section-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.68rem;
            font-weight: 600;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            color: var(--fx-accent);
            opacity: 0.65;
            margin: 0;
        }
        /* Feature cards grid */
        .nos-features-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.85rem;
        }
        @media (min-width: 560px) {
            .nos-features-grid { grid-template-columns: repeat(2, 1fr); }
            .nos-feature-card--wide { grid-column: 1 / -1; }
        }
        .nos-feature-card {
            background: rgba(15, 23, 42, 0.55);
            border: 1px solid var(--fx-border);
            border-radius: 10px;
            padding: 1.1rem 1.2rem;
            display: flex;
            flex-direction: column;
            gap: 0.45rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }
        .nos-feature-card:hover {
            border-color: rgba(0, 212, 255, 0.42);
            box-shadow: 0 0 18px rgba(0, 212, 255, 0.07);
        }
        .nos-feature-icon {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--fx-accent);
        }
        .nos-feature-icon svg {
            width: 17px;
            height: 17px;
            flex-shrink: 0;
        }
        .nos-feature-label {
            font-size: 0.68rem;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--fx-accent);
            opacity: 0.6;
        }
        .nos-feature-card h3 {
            font-size: 0.92rem;
            font-weight: 600;
            color: var(--fx-text);
            margin: 0;
            line-height: 1.35;
        }
        .nos-feature-card p {
            color: var(--fx-text-muted);
            font-size: 0.85rem;
            line-height: 1.7;
            margin: 0;
        }
        .nos-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem;
            margin-top: 0.2rem;
        }
        .nos-chip {
            background: rgba(0, 212, 255, 0.07);
            border: 1px solid rgba(0, 212, 255, 0.18);
            border-radius: 999px;
            padding: 0.18rem 0.6rem;
            font-size: 0.72rem;
            color: var(--fx-accent);
            font-family: 'ui-monospace', 'Consolas', monospace;
        }
        .nos-badge-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            margin-top: 0.2rem;
        }
        .nos-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.22rem 0.65rem;
            border-radius: 5px;
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid var(--fx-border);
            font-size: 0.75rem;
            color: var(--fx-text-muted);
            font-family: 'ui-monospace', 'Consolas', monospace;
        }
        .nos-badge span { color: var(--fx-accent); font-weight: 600; }

        /* ── Step-by-step guide sections ─────────────────────────────── */
        .nos-guide-section {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            scroll-margin-top: 1.5rem;
        }
        .nos-guide-section h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--fx-accent);
            letter-spacing: 0.05em;
            margin: 0;
        }
        .nos-guide-section > p {
            color: var(--fx-text-muted);
            font-size: 0.9rem;
            line-height: 1.8;
            margin: 0;
        }
        .nos-guide-section strong { color: var(--fx-text); font-weight: 600; }

        /* Reference tables (e.g. Output formats) */
        .nos-index-table {
            width: 100%;
            border-collapse: collapse;
            margin: 0.25rem 0 0;
            font-size: 0.86rem;
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid var(--fx-border);
            border-radius: 8px;
            overflow: hidden;
        }
        .nos-index-table th,
        .nos-index-table td {
            padding: 0.65rem 0.9rem;
            text-align: left;
            vertical-align: top;
            border-bottom: 1px solid var(--fx-border);
            color: var(--fx-text-muted);
            line-height: 1.55;
        }
        .nos-index-table th {
            background: rgba(0, 212, 255, 0.06);
            font-weight: 600;
            color: var(--fx-text);
            font-size: 0.78rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            font-family: 'Orbitron', sans-serif;
        }
        .nos-index-table tr:last-child td { border-bottom: none; }
        .nos-index-table code {
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid rgba(0, 212, 255, 0.18);
            border-radius: 3px;
            padding: 0.08em 0.35em;
            font-size: 0.9em;
            font-family: 'ui-monospace', 'Consolas', monospace;
            color: var(--fx-accent);
        }

        /* Building block cards */
        .nos-blocks-grid {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        .nos-block-card {
            border-left: 3px solid var(--fx-border);
            padding: 0.9rem 1.1rem;
            background: rgba(15, 23, 42, 0.45);
            border-radius: 0 8px 8px 0;
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            transition: border-color 0.2s ease;
        }
        .nos-block-card:hover { border-left-color: var(--fx-accent); }
        .nos-block-card-header {
            display: flex;
            align-items: center;
            gap: 0.55rem;
        }
        .nos-block-card-header svg {
            width: 15px;
            height: 15px;
            flex-shrink: 0;
            color: var(--fx-accent);
        }
        .nos-block-card-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            color: var(--fx-accent);
        }
        .nos-block-card-body {
            color: var(--fx-text-muted);
            font-size: 0.86rem;
            line-height: 1.72;
        }
        .nos-block-card-body strong { color: var(--fx-text); font-weight: 600; }
        .nos-block-card-body code {
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid rgba(0, 212, 255, 0.18);
            border-radius: 3px;
            padding: 0.05em 0.4em;
            font-size: 0.88em;
            font-family: 'ui-monospace', 'Consolas', monospace;
            color: var(--fx-accent);
        }

        /* In-page API reference (index only) */
        .nos-api-member-title {
            font-family: 'ui-monospace', 'Consolas', 'Cascadia Code', monospace;
            font-size: 1.08rem;
            font-weight: 600;
            color: var(--fx-text);
            letter-spacing: 0.03em;
            margin: 0;
        }
        .nos-api-subheading {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--fx-text);
            margin: 0;
            line-height: 1.35;
        }
        .nos-api-subheading code {
            font-family: 'ui-monospace', 'Consolas', 'Cascadia Code', monospace;
            font-size: 0.92em;
        }
        .nos-api-signature {
            font-family: 'ui-monospace', 'Consolas', 'Cascadia Code', monospace;
            font-size: 0.8rem;
            background: rgba(0, 212, 255, 0.06);
            border: 1px solid rgba(0, 212, 255, 0.18);
            border-radius: 8px;
            padding: 0.85rem 1rem;
            line-height: 1.55;
            overflow-x: auto;
            margin: 0;
        }
        /* Highlight.js: keep frame from .nos-api-signature, tokens from github-dark */
        .nos-api-signature code.hljs {
            display: block;
            padding: 0;
            margin: 0;
            background: transparent !important;
            font-size: inherit;
            line-height: inherit;
            font-family: inherit;
        }
        .nos-api-assoc {
            margin: 0.25rem 0 0;
            padding-left: 1.2rem;
            color: var(--fx-text-muted);
            font-size: 0.86rem;
            line-height: 1.78;
        }
        .nos-api-assoc li { margin-bottom: 0.45rem; }
        .nos-api-assoc code {
            background: rgba(0, 212, 255, 0.1);
            border: 1px solid rgba(0, 212, 255, 0.18);
            border-radius: 3px;
            padding: 0.08em 0.35em;
            font-size: 0.9em;
            font-family: 'ui-monospace', 'Consolas', monospace;
            color: var(--fx-accent);
        }
        .nos-api-note {
            font-size: 0.82rem;
            color: var(--fx-text-muted);
            border-left: 2px solid var(--fx-border);
            padding-left: 0.85rem;
            margin-top: 0.75rem;
            line-height: 1.65;
        }

        /* Sidebar section head item */
        .index-tree-item--head {
            padding: 0.9rem 0.75rem 0.2rem;
            pointer-events: none;
        }
        .index-tree-item--head .index-tree-head {
            padding: 0;
            width: 100%;
        }

        /* ── Prev / Next navigation ───────────────────────────────────── */
        .nos-nav-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            padding: 0.75rem 0;
        }
        .nos-nav-bar--top {
            border-bottom: 1px solid rgba(0, 212, 255, 0.12);
            margin-bottom: 1.75rem;
        }
        .nos-nav-bar--bottom {
            border-top: 1px solid rgba(0, 212, 255, 0.12);
            margin-top: 1.75rem;
        }
        .nos-nav-prev,
        .nos-nav-next {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.4rem 0.9rem;
            border-radius: 6px;
            background: rgba(0, 212, 255, 0.04);
            border: 1px solid rgba(0, 212, 255, 0.15);
            color: var(--fx-accent);
            text-decoration: none;
            font-size: 0.85rem;
            cursor: pointer;
            transition: background 0.18s, border-color 0.18s;
            user-select: none;
        }
        .nos-nav-prev:hover,
        .nos-nav-next:hover {
            background: rgba(0, 212, 255, 0.1);
            border-color: var(--fx-accent);
        }
        .nos-nav-prev.disabled,
        .nos-nav-next.disabled {
            pointer-events: none;
            opacity: 0;
        }
    </style>
{% endblock %}
{% set _docs_url = url_for('web.docs') %}
{% block body %}
<div class="landing-nos">
    <nav class="index-nav" role="navigation">
        <div class="index-nav__left">
            <button type="button" class="index-nav__toggle index-nav__menu-toggler" id="index-nav-toggle" aria-label="Toggle menu" aria-expanded="false">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
            <button type="button" class="index-nav__brand" id="index-sidebar-toggle" aria-label="nOS – Toggle docs menu" title="Toggle docs menu"><span class="nos-n">n</span>OS</button>
            <div class="index-nav__links" id="index-nav-links">
<a href="{{ url_for('web.download_page') }}" target="_blank" rel="noopener noreferrer">Download</a>
            <a href="{{ url_for('web.app_page') }}" target="_blank" rel="noopener noreferrer">Apps</a>
                <a href="https://github.com/seedx-lab/nos" target="_blank" rel="noopener noreferrer">Github</a>
            </div>
        </div>
        <a href="{{ url_for('web.login_page') }}" class="index-nav__login" target="_blank" rel="noopener noreferrer" aria-label="Log in">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
            <span>Log in</span>
        </a>
    </nav>
    <div class="index-overlay" id="index-overlay" aria-hidden="true"></div>
    <main class="index-main">
        <aside class="index-sidebar" id="index-sidebar">
            <div class="index-sidebar__inner">
                <ul class="index-tree" id="index-tree">
                    <li class="index-tree-item">
                        <a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-welcome"><i data-lucide="sparkles" class="menu-icon" aria-hidden="true"></i>Welcome to nOS</a>
                    </li>
                    <li class="index-tree-item">
                        <a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-install"><i data-lucide="server" class="menu-icon" aria-hidden="true"></i>Installation and startup</a>
                    </li>
                    <li class="index-tree-item">
                        <div class="index-tree-link" role="button" tabindex="0" data-toggle="guide-step-by-step">
                            <i data-lucide="list-ordered" class="menu-icon" aria-hidden="true"></i>Step-by-step Guide<span class="index-tree-toggle">▶</span>
                        </div>
                                <ul class="index-tree-children" id="children-guide-step-by-step">
                                    <li class="index-tree-item">
                                        <a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-intro"><i data-lucide="book-open" class="menu-icon" aria-hidden="true"></i>Introduction</a>
                                    </li>
                                    <li class="index-tree-item">
                                        <div class="index-tree-link" role="button" tabindex="0" data-toggle="guide-node">
                                            <i data-lucide="box" class="menu-icon" aria-hidden="true"></i>Node<span class="index-tree-toggle">▶</span>
                                        </div>
                                        <ul class="index-tree-children" id="children-guide-node">
                                        </ul>
                                    </li>
                                    <li class="index-tree-item">
                                        <div class="index-tree-link" role="button" tabindex="0" data-toggle="guide-workflow">
                                            <i data-lucide="git-branch" class="menu-icon" aria-hidden="true"></i>Workflow<span class="index-tree-toggle">▶</span>
                                        </div>
                                        <ul class="index-tree-children" id="children-guide-workflow">
                                            <li class="index-tree-item"><a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-guide-workflow-state-mapping"><i data-lucide="arrow-right-left" class="menu-icon" aria-hidden="true"></i>State mapping</a></li>
                                        </ul>
                                    </li>
                                    <li class="index-tree-item">
                                        <a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-guide-exception-handling"><i data-lucide="triangle-alert" class="menu-icon" aria-hidden="true"></i>Gestione eccezioni</a>
                                    </li>
                                    <li class="index-tree-item">
                                        <div class="index-tree-link" role="button" tabindex="0" data-toggle="nodi-custom">
                                            <i data-lucide="package" class="menu-icon" aria-hidden="true"></i>Custom node development<span class="index-tree-toggle">▶</span>
                                        </div>
                                        <ul class="index-tree-children" id="children-nodi-custom">
                                            <li class="index-tree-item"><a class="index-tree-link" href="{{ _docs_url }}#section-primo-nodo"><i data-lucide="rocket" class="menu-icon" aria-hidden="true"></i>First node development</a></li>
                                            <li class="index-tree-item"><a class="index-tree-link" href="{{ _docs_url }}#section-input-state-schema"><i data-lucide="database" class="menu-icon" aria-hidden="true"></i>Input state schema</a></li>
                                            <li class="index-tree-item"><a class="index-tree-link" href="{{ _docs_url }}#section-do-execute"><i data-lucide="zap" class="menu-icon" aria-hidden="true"></i>_do_execute</a></li>
                                            <li class="index-tree-item"><a class="index-tree-link" href="{{ _docs_url }}#section-register-node"><i data-lucide="bookmark-plus" class="menu-icon" aria-hidden="true"></i>Register a node</a></li>
                                        </ul>
                                    </li>
                                    <li class="index-tree-item">
                                        <div class="index-tree-link" role="button" tabindex="0" data-toggle="workflow-custom">
                                            <i data-lucide="git-merge" class="menu-icon" aria-hidden="true"></i>Custom workflow development<span class="index-tree-toggle">▶</span>
                                        </div>
                                        <ul class="index-tree-children" id="children-workflow-custom">
                                            <li class="index-tree-item"><a class="index-tree-link" href="{{ _docs_url }}#section-workflow-first"><i data-lucide="rocket" class="menu-icon" aria-hidden="true"></i>First workflow development</a></li>
                                            <li class="index-tree-item"><a class="index-tree-link" href="{{ _docs_url }}#section-workflow-define"><i data-lucide="list" class="menu-icon" aria-hidden="true"></i>define()</a></li>
                                            <li class="index-tree-item"><a class="index-tree-link" href="{{ _docs_url }}#section-workflow-state-mapping"><i data-lucide="arrow-right-left" class="menu-icon" aria-hidden="true"></i>State mapping</a></li>
                                            <li class="index-tree-item"><a class="index-tree-link" href="{{ _docs_url }}#section-workflow-links"><i data-lucide="route" class="menu-icon" aria-hidden="true"></i>Links</a></li>
                                        </ul>
                                    </li>
                                </ul>
                            </li>
                            <li class="index-tree-item">
                                <div class="index-tree-link" role="button" tabindex="0" data-toggle="api">
                                    <i data-lucide="library" class="menu-icon" aria-hidden="true"></i>API<span class="index-tree-toggle">▶</span>
                                </div>
                                <ul class="index-tree-children" id="children-api">
                                    <li class="index-tree-item">
                                        <div class="index-tree-link" role="button" tabindex="0" data-toggle="api-node">
                                            <i data-lucide="box" class="menu-icon" aria-hidden="true"></i>Node<span class="index-tree-toggle">▶</span>
                                        </div>
                                        <ul class="index-tree-children" id="children-api-node">
                                            <li class="index-tree-item"><a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-api-node-init"><i data-lucide="boxes" class="menu-icon" aria-hidden="true"></i><code>__init__</code></a></li>
                                            <li class="index-tree-item">
                                                <div class="index-tree-link" role="button" tabindex="0" data-toggle="api-node-properties">
                                                    <i data-lucide="sliders-horizontal" class="menu-icon" aria-hidden="true"></i>Properties<span class="index-tree-toggle">▶</span>
                                                </div>
                                                <ul class="index-tree-children" id="children-api-node-properties">
                                                    <li class="index-tree-item"><a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-api-default-output-format"><i data-lucide="palette" class="menu-icon" aria-hidden="true"></i>default_output_format</a></li>
                                                    <li class="index-tree-item"><a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-api-input-params-schema"><i data-lucide="list-checks" class="menu-icon" aria-hidden="true"></i>input_params_schema</a></li>
                                                    <li class="index-tree-item"><a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-api-input-state-schema"><i data-lucide="database" class="menu-icon" aria-hidden="true"></i>input_state_schema</a></li>
                                                    <li class="index-tree-item"><a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-api-output-schema"><i data-lucide="file-output" class="menu-icon" aria-hidden="true"></i>output_schema</a></li>
                                                    <li class="index-tree-item"><a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-api-node-exec-log"><i data-lucide="scroll-text" class="menu-icon" aria-hidden="true"></i>exec_log</a></li>
                                                    <li class="index-tree-item"><a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-api-metadata-schema"><i data-lucide="tags" class="menu-icon" aria-hidden="true"></i>metadata_schema</a></li>
                                                </ul>
                                            </li>
                                            <li class="index-tree-item">
                                                <div class="index-tree-link" role="button" tabindex="0" data-toggle="api-node-attributes">
                                                    <i data-lucide="brackets" class="menu-icon" aria-hidden="true"></i>Class attributes<span class="index-tree-toggle">▶</span>
                                                </div>
                                                <ul class="index-tree-children" id="children-api-node-attributes">
                                                    <li class="index-tree-item"><a class="index-tree-link index-tree-link--inpage" href="#" data-section="section-api-allowed-output-formats"><i data-lucide="filter" class="menu-icon" aria-hidden="true"></i>ALLOWED_OUTPUT_FORMATS</a></li>
                                                </ul>
