    /**
     * Get emoji icon based on file extension
     */
    function getFileIcon(ext) {
        const icons = {
            // Documents
            'pdf': '📕',
            'doc': '📘', 'docx': '📘',
            'xls': '📗', 'xlsx': '📗',
            'ppt': '📙', 'pptx': '📙',
            'txt': '📄',
            'md': '📝',
            'csv': '📊',
            // Code
            'js': '🟨', 'ts': '🟦',
            'py': '🐍',
            'html': '🌐', 'css': '🎨',
            'json': '{ }',
            'xml': '📋',
            'sql': '🗃️',
            // Images
            'jpg': '🖼️', 'jpeg': '🖼️', 'png': '🖼️', 'gif': '🖼️', 'svg': '🖼️', 'webp': '🖼️',
            // Archives
            'zip': '📦', 'rar': '📦', 'tar': '📦', 'gz': '📦', '7z': '📦',
            // Media
            'mp3': '🎵', 'wav': '🎵', 'ogg': '🎵',
            'mp4': '🎬', 'avi': '🎬', 'mov': '🎬', 'mkv': '🎬',
            // Data
            'db': '💾', 'sqlite': '💾',
            // Default
            'default': '📁'
        };
        return icons[ext] || icons['default'];
